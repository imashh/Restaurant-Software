rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings/restaurant
    // Fields: name, logoUrl, contact, address, intro, theme
    //
    // Collection: categories
    // Fields: name, order
    //
    // Collection: menuItems
    // Fields: name, description, price, categoryId, imageUrl, isBestSeller, isTodayPick, isSpecialOffer, isVeg, available
    //
    // Collection: tables
    // Fields: number, qrCodeUrl
    //
    // Collection: orders
    // Fields: customerName, tableNumber, items, notes, status, total, createdAt
    //
    // Collection: users
    // Fields: email, role
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "grafiqo.np@gmail.com" && request.auth.token.email_verified == true));
    }

    function isKitchen() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'kitchen' || 
         (request.auth.token.email == "v.divash@gmail.com" && request.auth.token.email_verified == true) ||
         isAdmin());
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }

    function isValidNumber(field, min) {
      return request.resource.data[field] is number && request.resource.data[field] >= min;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Restaurant Settings
    match /settings/restaurant {
      allow read: if true; // Publicly readable for customer flow
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Menu Items
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tables
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending' &&
                      isValidString('customerName', 1, 50) &&
                      request.resource.data.items is list &&
                      request.resource.data.items.size() > 0;
      allow update: if isAdmin() || 
                      (isKitchen() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && resource.data.status == 'pending' && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // Users (Staff Roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
